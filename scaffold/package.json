{
  "name": "frontend",
  "private": true,
  "version": "1.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:strict": "tsc -b && vite build",
    "build:analyze": "ANALYZE=1 vite build && echo '\\nBundle stats: open dist/bundle-stats.html in a browser'",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rules": "cd .. && firebase emulators:exec --only firestore,storage,auth --project demo-zaryahplus 'cd frontend && npx vitest run --config vitest.rules.config.ts'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:auth": "cd .. && firebase emulators:exec --only auth,firestore --project demo-zaryahplus 'cd frontend && VITE_USE_AUTH_EMULATOR=true playwright test auth-flow'",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync",
    "release:android": "npm run build && cap sync android && cd android && ./gradlew bundleRelease",
    "release:android:apk": "npm run build && cap sync android && cd android && ./gradlew assembleRelease",
    "release:ios": "npm run build && cap sync ios && cap open ios",
    "prepare": ""
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "overrides": {
    "protobufjs": "^7.5.6"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/splash-screen": "~8.0.0",
    "@capacitor/status-bar": "~8.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@sentry/react": "^10.51.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.100.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.7.0",
    "framer-motion": "^12.25.0",
    "html-to-image": "^1.11.13",
    "i18next": "^26.0.4",
    "lightweight-charts": "^5.2.0",
    "meshline": "^3.3.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.6",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "postcss": "^8.5.14",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.2",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.5"
  }
}