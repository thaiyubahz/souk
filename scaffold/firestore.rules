rules_version = '2';

// ============================================================================
// PRODUCTION rules for the Souk.
//
// These apply once the Souk is merged into the main ZaryahPlus app, where the
// user is ALREADY logged in. Listings are publicly readable, but only a
// signed-in user can create one, and only its owner can edit/delete it. A halal
// guardrail rejects prohibited items at the database level.
//
// NOTE: the live PROTOTYPE database currently runs the relaxed rules in
// firestore.prototype.rules (no login). Switch to these when login is in place.
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // A listing must have a real name, a non-negative numeric price, and an
    // image string small enough to keep the document under Firestore's 1 MB
    // limit.
    function validListing(d) {
      return d.name is string && d.name.size() > 0 && d.name.size() <= 200
        && d.price is number && d.price >= 0
        && d.img is string && d.img.size() < 1400000;
    }

    // Halal guardrail — reject a listing whose name contains a prohibited term.
    // (Database-level backup to the same check in the app code.)
    function isHalal(d) {
      return !(d.name.lower().matches('.*(weapon|guns?|rifle|pistol|firearm|ammo|ammunition|explosive|alcohol|wine|beer|liquor|whisky|vodka|drugs?|cocaine|heroin|cannabis|marijuana|pork|bacon|gambling|casino|lottery|betting|riba|tobacco|cigarette|vape|porn).*'));
    }

    // Products / listings — public to read; owner-gated to write.
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn()
        && validListing(request.resource.data)
        && isHalal(request.resource.data)
        && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.sellerId == request.auth.uid
        && validListing(request.resource.data)
        && isHalal(request.resource.data);
      allow delete: if isSignedIn()
        && resource.data.sellerId == request.auth.uid;
    }

    // Seller profiles — public to read; only the owner can write their own.
    match /sellers/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // KYC — strictly private to the user.
    match /kyc/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Orders — strictly private to the user.
    match /orders/{orderId} {
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    // Chats — only the conversation's participants. (Starting template; refine
    // alongside the real messaging feature.)
    match /chats/{chatId} {
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
